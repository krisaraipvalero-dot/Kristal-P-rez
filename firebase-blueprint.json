{
  "entities": {
    "Score": {
      "title": "Score",
      "description": "A player's high score in the Enzyme-Man game.",
      "type": "object",
      "properties": {
        "playerName": {
          "type": "string",
          "description": "The name of the player."
        },
        "score": {
          "type": "integer",
          "description": "The score achieved."
        },
        "timestamp": {
          "type": "string",
          "format": "date-time",
          "description": "When the score was recorded."
        },
        "userId": {
          "type": "string",
          "description": "The unique ID of the player."
        }
      },
      "required": ["playerName", "score", "timestamp", "userId"]
    }
  },
  "firestore": {
    "/leaderboard/{scoreId}": {
      "schema": "Score",
      "description": "Global leaderboard for Enzyme-Man."
    }
  }
}
